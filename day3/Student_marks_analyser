total_marks = 0
count = 0
highest = None
lowest = None

answer = input("Do you want to enter marks? (yes/no): ")

while answer.lower() == "yes":

    s1 = int(input("Enter Kannada Marks: "))
    s2 = int(input("Enter English Marks: "))
    s3 = int(input("Enter Science Marks: "))
    s4 = int(input("Enter Social Marks: "))
    s5 = int(input("Enter Maths Marks: "))

    total = s1 + s2 + s3 + s4 + s5

    total_marks = total_marks + total
    count = count + 5


    for mark in [s1, s2, s3, s4, s5]:
        if highest is None or mark > highest:
            highest = mark

        if lowest is None or mark < lowest:
            lowest = mark

    answer = input("Do you want to enter marks again? (yes/no): ")


if count > 0:
    average = total_marks / count

    print("\n Result Summary:")
    print("Total Marks:", total_marks)
    print("Average Marks:", average)
    print("Highest Marks:", highest)
    print("Lowest Marks:", lowest)
else:
    print("No marks were entered.")

print("\nThanks for using the system!")










